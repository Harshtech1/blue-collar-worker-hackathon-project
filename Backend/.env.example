# =============================================
# RAHI Backend — Environment Template
# Copy this file to .env and fill in YOUR values.
# NEVER commit the actual .env file to git.
# =============================================

PORT=5000
NODE_ENV=development

# MongoDB (Atlas for production, local for dev)
MONGO_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/<DB_NAME>?retryWrites=true&w=majority
# MONGO_URI=mongodb://localhost:27017/rahi_db   # <- for local dev without Docker

# JWT — use a long, random string (min 64 chars)
JWT_SECRET=replace_this_with_a_long_random_secret_string_minimum_64_characters

# Admin credentials (server-side only — never expose via VITE_)
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_strong_admin_password_here

# SMTP (Gmail App Password recommended)
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
